# ── Database (production) ──────────────────────────────────────────
# Leave both unset for local dev → uses file:data/jobs.db automatically.
# For Vercel, create a free DB at https://turso.tech (9 GB free):
#   turso db create job-radar
#   turso db show job-radar --url        → TURSO_DATABASE_URL
#   turso db tokens create job-radar     → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Cron protection ─────────────────────────────────────────────────
# Any random string. The same value goes in GitHub Actions secrets.
# Generate one:  openssl rand -hex 24
CRON_SECRET=

# ── Notifications (either or both; free) ────────────────────────────
# Telegram: message @BotFather → /newbot → copy the token.
# Then message your new bot once, and get your chat id from:
#   https://api.telegram.org/bot<TOKEN>/getUpdates   (look for "chat":{"id":...})
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy.sh: no signup. Pick a long random topic name, subscribe to it
# in the ntfy mobile app, done.
NTFY_TOPIC=

# ── Misc ────────────────────────────────────────────────────────────
# Public URL of the deployed app (used in notification links)
APP_URL=

# Local scheduler interval in minutes (self-hosted/docker only; default 45)
SCAN_INTERVAL_MINUTES=
